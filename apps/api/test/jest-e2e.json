{
  "extensionsToTreatAsEsm": [".ts"],
  "moduleFileExtensions": ["js", "json", "ts"],
  "rootDir": ".",
  "testEnvironment": "node",
  "testRegex": ".e2e-spec.ts$",
  "transform": {
    "^.+\\.(t|j)s$": ["ts-jest", { "useESM": true }]
  },
  "moduleNameMapper": {
    "^.*generated/prisma/client(\\.js)?$": "<rootDir>/mocks/prisma-client.ts",
    "^(\\.{1,2}/.*)\\.js$": "$1"
  }
}
