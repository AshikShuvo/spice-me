# Copy to `.env` and adjust for local development.
# Turborepo: add root `.env` only if you want variables shared across apps; this file documents api-specific vars.

PORT=3001
NODE_ENV=development

# Browser clients (Next.js web). Comma-separated; default is http://localhost:3003
CORS_ORIGINS=http://localhost:3003
DATABASE_URL="postgresql://user:password@localhost:5432/spiceme?schema=public"

# JWT — use long random secrets in production (access and refresh must differ)
JWT_SECRET=change-me-access-secret-min-32-chars-recommended!!
JWT_REFRESH_SECRET=change-me-refresh-secret-min-32-chars-recommended!!
