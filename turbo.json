{
  "$schema": "https://turborepo.dev/schema.json",
  "ui": "tui",
  "tasks": {
    "build": {
      "dependsOn": ["^build"],
      "inputs": ["$TURBO_DEFAULT$", ".env*"],
      "outputs": [".next/**", "!.next/cache/**", "dist/**"],
      "env": [
        "PORT",
        "DATABASE_URL",
        "NODE_ENV",
        "JWT_SECRET",
        "JWT_REFRESH_SECRET",
        "NEXTAUTH_SECRET",
        "AUTH_SECRET",
        "NEXTAUTH_URL",
        "NEXT_PUBLIC_API_URL",
        "CORS_ORIGINS"
      ]
    },
    "lint": {
      "dependsOn": ["^lint"]
    },
    "check-types": {
      "dependsOn": ["^check-types"]
    },
    "dev": {
      "cache": false,
      "persistent": true,
      "env": [
        "PORT",
        "DATABASE_URL",
        "NODE_ENV",
        "JWT_SECRET",
        "JWT_REFRESH_SECRET",
        "NEXTAUTH_SECRET",
        "AUTH_SECRET",
        "NEXTAUTH_URL",
        "NEXT_PUBLIC_API_URL",
        "CORS_ORIGINS"
      ]
    }
  }
}
